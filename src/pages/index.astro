---
import Layout from '../layouts/Layout.astro';
import logo from '../assets/sweet-string.png';
---

<Layout>
	<main class="page-shell">
		<section class="hero">
			<div class="hero-copy">
				<img src={logo.src} alt="Sweet String logo" class="logo" />
				<p class="eyebrow">Sweet String</p>
				<h1>Acoustic pop &amp; OPM from the Philippines</h1>
				<p class="copy">
					A modern acoustic collective playing original songs and beloved Filipino favorites.
					Perfect for corporate events, intimate cafes, and weekend gigs.
				</p>
				<div class="hero-actions">
					<a class="button button-primary" href="#video">Watch the band</a>
					<a class="button button-secondary" href="#gallery">Photo gallery</a>
				</div>
			</div>
			<div class="hero-media">
				<img
					src="https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?auto=format&fit=crop&w=1200&q=80"
					alt="Sweet String acoustic band performing live"
					loading="eager"
				/>
			</div>
		</section>

		<section class="section about">
			<div class="section-content">
				<h2>About Sweet String</h2>
				<p>
					Sweet String is a rising acoustic band from the Philippines blending pop melodies, OPM classics, and soulful harmonies.
					Their polished acoustic sound is built for listeners who love warm vocals, guitar-driven arrangements, and festival-ready energy.
				</p>
			</div>
		</section>

		<section id="gallery" class="section gallery-section">
			<h2>Photo gallery</h2>
			<div class="gallery-grid">
				<figure>
					<img src="https://images.unsplash.com/photo-1497032205916-ac775f0649ae?auto=format&fit=crop&w=1000&q=80" alt="Acoustic guitar performance" />
					<figcaption>Live performance in Manila</figcaption>
				</figure>
				<figure>
					<img src="https://images.unsplash.com/photo-1511376777868-611b54f68947?auto=format&fit=crop&w=1000&q=80" alt="Band rehearsing" />
					<figcaption>Rehearsal session</figcaption>
				</figure>
				<figure>
					<img src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1000&q=80" alt="Crowd enjoying live acoustic music" />
					<figcaption>Crowd enjoying the set</figcaption>
				</figure>
			</div>
		</section>

		<section id="video" class="section video-section">
			<h2>Video gallery</h2>
			<p class="section-copy">
				Sample performance and video references for Sweet String. Replace these with your own YouTube videos when ready.
			</p>
			<div class="video-grid">
				<div class="video-card">
					<iframe
						width="560"
						height="315"
						src="https://www.youtube.com/embed/7NOSDKb0HlU"
						title="Sweet String sample performance"
						allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
						allowfullscreen
					></iframe>
					<h3>Featured music video</h3>
					<p>Acoustic pop performance with soulful storytelling and live energy.</p>
				</div>

				<div class="video-card video-card-secondary">
					<a href="https://www.youtube.com/watch?v=7NOSDKb0HlU" target="_blank" rel="noreferrer">
						<div class="video-thumb"></div>
						<div>
							<h3>Watch the full set</h3>
							<p>YouTube preview of the band's signature acoustic sound.</p>
						</div>
					</a>
				</div>
			</div>
		</section>

		<section class="section contact-section">
			<div>
				<h2>Book Sweet String</h2>
				<p>
					Ready to bring acoustic pop and OPM to your next event? Contact the band for bookings, gigs, and collaborations.
				</p>
				<p class="contact-info">
					Email: <a href="mailto:hello@sweetstring.band">hello@sweetstring.band</a><br />
					IG: <a href="https://instagram.com" target="_blank" rel="noreferrer">@sweetstringband</a>
				</p>
			</div>
		</section>
	</main>
</Layout>

<style>
	.page-shell {
		max-width: 1240px;
		margin: 0 auto;
		padding: 24px 24px 48px;
	}

	.hero {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		align-items: center;
		gap: 32px;
		padding: 48px 0 32px;
	}

	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.24em;
		font-size: 0.85rem;
		font-weight: 700;
		color: #7c3aed;
		margin: 0 0 18px;
	}

	.logo {
		width: 120px;
		height: auto;
		margin-bottom: 24px;
	}

	h1 {
		font-size: clamp(2.75rem, 3.5vw, 4.5rem);
		line-height: 1.02;
		margin: 0 0 24px;
		max-width: 12ch;
	}

	.copy,
	.section-copy {
		font-size: 1.05rem;
		line-height: 1.85;
		max-width: 680px;
		color: #4b5563;
		margin: 0;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 16px;
		margin-top: 32px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 14px 22px;
		border-radius: 999px;
		font-weight: 700;
		text-decoration: none;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.button:hover {
		transform: translateY(-1px);
	}

	.button-primary {
		background: linear-gradient(135deg, #7c3aed 0%, #4338ca 100%);
		color: white;
		box-shadow: 0 18px 40px rgba(124, 58, 237, 0.18);
	}

	.button-secondary {
		background: rgba(255, 255, 255, 0.9);
		border: 1px solid rgba(99, 102, 241, 0.15);
		color: #4338ca;
	}

	.hero-media img {
		width: 100%;
		height: auto;
		border-radius: 32px;
		box-shadow: 0 24px 80px rgba(15, 23, 42, 0.12);
		object-fit: cover;
	}

	.section {
		padding: 64px 0;
	}

	.about {
		background: rgba(99, 102, 241, 0.05);
		border-radius: 32px;
		padding: 56px;
	}

	.gallery-section h2,
	.video-section h2,
	.contact-section h2 {
		font-size: clamp(2rem, 2.5vw, 3rem);
		margin-bottom: 24px;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 22px;
	}

	.gallery-grid figure {
		margin: 0;
		overflow: hidden;
		border-radius: 24px;
		background: white;
		box-shadow: 0 20px 60px rgba(15, 23, 42, 0.08);
	}

	.gallery-grid img {
		width: 100%;
		height: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		display: block;
	}

	.gallery-grid figcaption {
		padding: 16px;
		font-size: 0.95rem;
		color: #6b7280;
	}

	.video-grid {
		display: grid;
		grid-template-columns: 1.4fr 0.8fr;
		gap: 24px;
		align-items: start;
	}

	.video-card {
		background: white;
		border-radius: 32px;
		padding: 28px;
		box-shadow: 0 24px 80px rgba(15, 23, 42, 0.08);
	}

	.video-card-secondary {
		display: flex;
		align-items: center;
		min-height: 100%;
		justify-content: center;
	}

	.video-card-secondary a {
		display: grid;
		grid-template-columns: 140px 1fr;
		gap: 20px;
		text-decoration: none;
		color: inherit;
		align-items: center;
	}

	.video-thumb {
		width: 140px;
		height: 90px;
		border-radius: 18px;
		background: linear-gradient(135deg, #7c3aed, #4338ca);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.12);
	}

	.video-card h3,
	.video-card-secondary h3 {
		margin: 18px 0 12px;
		font-size: 1.25rem;
	}

	.video-card p,
	.video-card-secondary p {
		margin: 0;
		color: #4b5563;
		line-height: 1.8;
	}

	.video-card iframe {
		width: 100%;
		min-height: 360px;
		border: 0;
		border-radius: 24px;
	}

	.contact-section {
		background: linear-gradient(180deg, rgba(124, 58, 237, 0.08), transparent 55%);
		border-radius: 32px;
		padding: 56px;
	}

	.contact-info {
		margin: 24px 0 0;
		font-size: 1rem;
		color: #4338ca;
	}

	.contact-info a {
		color: #4338ca;
		font-weight: 700;
	}

	@media (max-width: 960px) {
		.hero {
			grid-template-columns: 1fr;
		}

		.video-grid {
			grid-template-columns: 1fr;
		}

		.gallery-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 680px) {
		.page-shell {
			padding: 16px;
		}

		.hero {
			padding-top: 32px;
		}

		.hero-actions {
			flex-direction: column;
			align-items: stretch;
		}

		.button {
			width: 100%;
		}

		.video-card iframe {
			min-height: 240px;
		}

		.logo {
			width: 80px;
		}
	}
</style>
